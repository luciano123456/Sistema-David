@{
    ViewBag.Title = "Información de Ventas";
    var qClienteId = Request["clienteId"];
    var qVentaId = Request["ventaId"];
    var qModo = Request["modo"];
    var qFrom = Request["from"];
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="~/Estilos/bootstrap.min.css" rel="stylesheet" />
<link href="~/Estilos/InformacionVenta.css?v=20" rel="stylesheet" />
<link href="~/Estilos/PagosNuevoModif.css" rel="stylesheet" />

<div class="container-fluid pay-nm info-ventas-page"
     id="infoVentasApp"
     data-cliente-id="@qClienteId"
     data-venta-id="@qVentaId"
     data-tipo="@Request["tipo"]"
     data-modo="@qModo"
     data-from="@qFrom">

    <div class="page-bg"></div>
    <div class="page-grid"></div>

    <div class="topbar">
        <div class="topbar-left">
            <div class="topbar-badge">
                <i class="bi bi-receipt-cutoff"></i>
                <span>Información de Ventas</span>
            </div>

            <div class="topbar-text">
                <h1 class="title">Ventas del cliente <strong id="clienteNombreTop">—</strong></h1>
                <div class="subtitle">Detalle de productos, pagos, intereses e historial</div>

                @if (!string.IsNullOrEmpty(qFrom) && qFrom.ToLower() == "cobranzas")
                {
                    <div class="origin-pill mt-2">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Origen: Cobranzas</span>
                    </div>
                }
            </div>
        </div>

        <div class="topbar-actions">
            <div class="form-check form-switch saldadas-toolbar" id="switchSaldadasWrap" title="Mostrar también ventas saldadas">
                <input class="form-check-input" type="checkbox" role="switch" id="swSaldadas">
                <label class="form-check-label" for="swSaldadas">
                    Mostrar saldadas
                    <span id="swStats" class="sw-stats-pill"></span>
                </label>
            </div>

            <button id="btnExportPdf" class="btn btn-success-soft">
                <i class="bi bi-filetype-pdf me-1"></i>
                <span>Exportar PDF</span>
            </button>

            <button id="btnRefrescar" class="btn btn-slate">
                <i class="bi bi-arrow-repeat me-1"></i>
                <span>Refrescar</span>
            </button>

            <a class="btn btn-ghost" href="javascript:history.back()">
                <i class="bi bi-arrow-left-short me-1"></i>
                <span>Volver</span>
            </a>
        </div>
    </div>

    <div class="card glass main-card">
        <div class="card-header sticky d-flex align-items-center gap-2">
            <i class="bi bi-list-ul"></i>
            <span>Ventas</span>
        </div>

        <div class="card-body p-2 p-md-3">
            <div id="ventasAccordion" class="ventas-accordion">
                <div class="empty py-5" id="emptyState">
                    <i class="bi bi-ui-checks-grid"></i>
                    <div class="empty-title">Sin ventas</div>
                    <div class="empty-sub">No se encontraron ventas para este cliente</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL: Agregar interés -->
<div class="modal fade" id="interesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-mobile">
        <div class="modal-content cobranza-modal">
            <div class="modal-header cobranza-header">
                <h5 class="modal-title">
                    <i class="bi bi-percent me-2"></i>
                    Agregar interés
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form class="row g-3" id="formInteres">
                    <input type="hidden" id="Int_IdVenta" />

                    <div class="col-12 col-md-6">
                        <label class="form-label small">Importe del interés</label>
                        <input type="text" id="Int_Valor" class="form-control form-control-sm" value="0" />
                        <div class="form-text">Usa puntos para miles (ej: 10.000)</div>
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label small">Tipo de interés</label>
                        <select id="Int_Tipo" class="form-select form-select-sm text-dark">
                            <option value="">Seleccionar</option>
                            <option value="VISITA CON CAMBIO">VISITA CON CAMBIO</option>
                            <option value="INTERES DE 30 DIAS">INTERES DE 30 DIAS</option>
                            <option value="INTERES DE 60 DIAS">INTERES DE 60 DIAS</option>
                            <option value="PROMESA DE PAGO">PROMESA DE PAGO</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label small">Observación (opcional)</label>
                        <input type="text" id="Int_Obs" class="form-control form-control-sm text-dark" />
                    </div>

                    <div id="Int_Errores" class="alert alert-danger d-none"></div>
                </form>
            </div>

            <div class="modal-footer cobranza-footer">
                <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cerrar</button>
                <button id="btnGuardarInteres" type="button" class="btn btn-primary">
                    <i class="bi bi-check2-circle me-1"></i>
                    Guardar interés
                </button>
            </div>
        </div>
    </div>
</div>

<script src="~/Scripts/jquery-3.4.1.min.js"></script>
<script src="~/Scripts/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.18.1/moment.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/1.3.2/jspdf.min.js"></script>

<script src="~/JavaScript/InformacionVenta.js?v=4.0"></script>