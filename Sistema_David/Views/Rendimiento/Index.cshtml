@{
    ViewBag.Title = "Rendimientos";
}

<link href="~/Content/Datatable/css/jquery.dataTables.min.css" rel="stylesheet" />
<link href="~/Content/Datatable/css/responsive.dataTables.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet" />
<link href="~/Estilos/redisenopantallas.css?v=4.0" rel="stylesheet" />
<link href="~/Estilos/rendimiento.css?v4.1" rel="stylesheet" />

<body class="ve-dark">
    @if (ViewData["ErrorPermisos"] == null)
    {
        <div class="container page-99 py-3">



            <!-- =========================
         HEADER
    ========================== -->
            <section class="cc-header mb-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="cc-badge">
                            <i class="fa fa-line-chart"></i>
                        </div>

                        <div>
                            <h2 class="m-0 fw-800">Rendimientos</h2>
                            <div class="text-muted-cc">
                                Control diario y mensual de ventas, cobranzas, capital y clientes ausentes
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-light" id="btnToggleFiltrosRendimiento">
                            <i id="iconFiltrosRendimiento" class="fa fa-chevron-down"></i> Filtros
                        </button>

                        <div class="switch-rendimiento">
                            <button type="button" class="btn-switch active" id="btnRendDiario">
                                <i class="fa fa-calendar-o me-1"></i> Diario
                            </button>

                            <button type="button" class="btn-switch" id="btnRendMensual">
                                <i class="fa fa-bar-chart me-1"></i> Mensual
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- =========================
         KPIS
    ========================== -->
            <section class="mb-4">
                <div class="row g-3">
                    <div class="col-12 col-sm-6 col-xl">
                        <div class="cc-stat h-100">
                            <div class="label">Total Venta</div>
                            <div class="value" id="totventa">0</div>
                        </div>
                    </div>

                    <div class="col-12 col-sm-6 col-xl">
                        <div class="cc-stat h-100">
                            <div class="label">Total Cobro</div>
                            <div class="value" id="totcobro">0</div>
                        </div>
                    </div>

                    <div class="col-12 col-sm-6 col-xl">
                        <div class="cc-stat h-100">
                            <div class="label">Total Interés</div>
                            <div class="value" id="totinteres">0</div>
                        </div>
                    </div>

                    <div class="col-12 col-sm-6 col-xl" id="divTotalCapital" hidden>
                        <div class="cc-stat h-100">
                            <div class="label">Capital</div>
                            <div class="value text-danger" id="totRestante">0</div>
                        </div>
                    </div>

                    <div class="col-12 col-sm-6 col-xl" id="divTotalEnRojo" hidden>
                        <div class="cc-stat h-100">
                            <div class="label">Capital en rojo</div>
                            <div class="value text-danger" id="totDeuda">0</div>
                        </div>
                    </div>

                    <div class="col-12 col-sm-6 col-xl">
                        <div class="cc-stat h-100">
                            <div class="label">Total Efectivo</div>
                            <div class="value" id="totefectivo">0</div>
                        </div>
                    </div>

                    <div class="col-12 col-sm-6 col-xl">
                        <div class="cc-stat h-100">
                            <div class="label">Total Transferencia</div>
                            <div class="value" id="tottransferencia">0</div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- =========================
         FILTROS
    ========================== -->
            <section id="panelFiltrosRendimiento" class="card-glass p-3 mb-4 d-none">
                <form id="formFiltrosRendimiento" onsubmit="return false;">
                    <div class="row g-3">

                        <div class="col-12 col-md-3 col-xl-2">
                            <label class="form-label">Fecha Desde</label>
                            <input type="date" id="FechaDesde" class="form-control" />
                        </div>

                        <div class="col-12 col-md-3 col-xl-2">
                            <label class="form-label">Fecha Hasta</label>
                            <input type="date" id="FechaHasta" class="form-control" />
                        </div>

                        <div class="col-12 col-md-3 col-xl-2">
                            <label class="form-label">Tipo de Negocio</label>
                            <select id="TipoNegocio" class="form-select">
                                <option value="-1">Todos</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-3 col-xl-2">
                            <label class="form-label">Método de Pago</label>
                            <select id="MetodoPago" class="form-select">
                                <option value="Todos">Todos</option>
                                <option value="Efectivo">Efectivo</option>
                                <option value="Transferencia Propia">Transferencia Propia</option>
                                <option value="Transferencia a Terceros">Transferencia a Terceros</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-3 col-xl-2">
                            <label class="form-label" id="lblCuentaPago" hidden>Cuenta Bancaria</label>
                            <select id="CuentaPago" class="form-select" hidden>
                                <option value="-1">Todos</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-3 col-xl-2 d-flex align-items-end">
                            <div id="divComprobantesEnviados" class="form-check form-switch w-100 justify-content-start ps-0">
                                <label class="form-check-label d-block mb-2" for="ComprobantesEnviados">Enviados</label>
                                <input class="form-check-input ms-0" type="checkbox" id="ComprobantesEnviados">
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex flex-wrap gap-2">
                                <button type="button" class="btn btn-primary" id="btnAplicarFiltrosRendimiento">
                                    <i class="fa fa-search me-1"></i> Aplicar
                                </button>

                                <button type="button" class="btn btn-outline-light" id="btnLimpiarFiltrosRendimiento">
                                    <i class="fa fa-eraser me-1"></i> Limpiar
                                </button>

                                <button type="button" class="btn btn-outline-info" id="btnFechaHoy">
                                    <i class="fa fa-calendar me-1"></i> Hoy
                                </button>

                                <button type="button" class="btn btn-outline-success" id="btnFechaMensual">
                                    <i class="fa fa-calendar-check-o me-1"></i> Mensual
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </section>

            <div id="globalLoading" class="global-loading hidden">
                <div class="loading-box">
                    <div class="spinner"></div>
                    <div class="loading-text">Cargando datos...</div>
                </div>
            </div>

            <!-- =========================
         VISTA DIARIA
    ========================== -->
            <section id="vistaDiariaRendimiento">

                <div class="row g-4">

                    <!-- Vendedores -->
                    <div class="col-12 col-xl-3">
                        <div class="card-glass h-100 p-3">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="fw-bold text-white">
                                    <i class="fa fa-users me-2"></i> Lista de Vendedores
                                </div>

                            </div>

                            <div id="contenedorlista" style="max-height: 650px; overflow-y: auto;">
                                <ul id="listaUsuarios" class="list-group list-group-flush">
                                    <li class="list-group-item d-flex justify-content-end align-items-center bg-transparent border-0 text-white">
                                        <div class="acciones-usuario-header">
                                            <div id="divVentasCabecera" hidden>V</div>
                                            <div>C</div>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Centro -->
                    <div class="col-12 col-xl-9">

                        <!-- Tabla principal -->
                        <div id="RendimientoDiario" class="card-glass p-3 mb-4">
                            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                                <div class="fw-bold text-white">
                                    <i class="fa fa-table me-2"></i> Rendimiento Diario
                                </div>

                                <div class="dropdown">
                                    <button class="btn btn-outline-light dropdown-toggle" type="button" id="dropdownColumnas" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="fa fa-cog me-2"></i> Config. Columnas
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownColumnas" id="configColumnasMenu"></ul>
                                </div>
                            </div>

                            <div class="table-responsive dt-dark-wrap">
                                <table class="display nowrap dt-dark w-100" id="grdRendimiento">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Metodo Pago</th>
                                            <th>Cuenta Bancaria</th>
                                            <th>Cliente</th>
                                            <th>Capital Inicial</th>
                                            <th>Ventas</th>
                                            <th>Cobros</th>
                                            <th>Interes</th>
                                            <th>Capital Final</th>
                                            <th>Proximo Cobro</th>
                                            <th>Vencimiento</th>
                                            <th>Tipo de Negocio</th>
                                            <th>Descripcion</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>

                        <!-- Clientes ausentes -->
                        <div id="RendimientoClientesAusentes" class="card-glass p-3">
                            <div class="fw-bold text-white mb-3">
                                <i class="fa fa-user-times me-2"></i> Clientes Ausentes
                            </div>

                            <div class="table-responsive dt-dark-wrap">
                                <table class="display nowrap dt-dark w-100" id="grdClientesAusentes">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Cliente</th>
                                            <th>Cobrador</th>
                                            <th>Observacion</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>

                    </div>
                </div>

                <div id="dashboardRendimiento" class="dashboard-rendimiento mt-4" hidden>

                    <div class="dashboard-card">
                        <div class="title">Ventas vs Cobros</div>
                        <canvas id="chartVentasCobros"></canvas>
                    </div>

                    <div class="dashboard-card">
                        <div class="title">Distribución de Cobros</div>
                        <canvas id="chartMetodosPago"></canvas>
                    </div>

                    <div class="dashboard-card full">
                        <div class="title">Capital</div>
                        <canvas id="chartCapital"></canvas>
                    </div>

                    <!-- 🔥 NUEVOS -->
                    <div class="dashboard-card full">
                        <div class="title">Evolución mensual - Ventas</div>
                        <canvas id="chartVentasMensual"></canvas>
                    </div>

                    <div class="dashboard-card full">
                        <div class="title">Evolución mensual - Cobros</div>
                        <canvas id="chartCobrosMensual"></canvas>
                    </div>

                </div>
            </section>

            <!-- =========================
         VISTA MENSUAL
    ========================== -->
            <section id="vistaMensualRendimiento" hidden>

                <div class="row g-4">

                    <div class="col-12 col-xl-8">
                        <div id="RendimientoMensual" class="card-glass p-3 h-100">
                            <div class="fw-bold text-white mb-3">
                                <i class="fa fa-area-chart me-2"></i> Rendimiento Mensual por día
                            </div>

                            <div class="table-responsive dt-dark-wrap">
                                <table class="display nowrap dt-dark w-100" id="grdRendimientoGeneral">
                                    <thead>
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Capital Inicial</th>
                                            <th>Ventas</th>
                                            <th>Cobros</th>
                                            <th>Capital Final</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-xl-4">
                        <div id="RendimientoCobrado" class="card-glass p-3 h-100">
                            <div class="fw-bold text-white mb-3">
                                <i class="fa fa-money me-2"></i> Cobros de vendedores
                            </div>

                            <div class="table-responsive dt-dark-wrap">
                                <table class="display nowrap dt-dark w-100" id="grdRendimientoCobrado">
                                    <thead>
                                        <tr>
                                            <th>Vendedor</th>
                                            <th>Total Cobrado</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>

            </section>
        </div>
    }
    else
    {
        <div class="container py-4">
            <div class="alert alert-danger">
                Error: No tienes permisos para acceder a esta pantalla
            </div>
        </div>
    }

    <!-- =========================
         MODAL COMPROBANTE
    ========================== -->
    <div class="modal fade" id="modalComprobante" tabindex="-1" aria-labelledby="modalComprobanteLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header colorEncabezado">
                    <h5 class="modal-title" id="modalComprobanteLabel">
                        <i class="fa fa-file-image-o me-2"></i> Comprobante
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body text-center">
                    <img id="imagenComprobante" src="" alt="Comprobante" class="img-fluid rounded shadow-sm">
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
</body>

@section scripts {
    <script src="~/Content/Datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/Content/Datatable/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/locale/es.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/JavaScript/Rendimiento.js?v=4.5"></script>
}